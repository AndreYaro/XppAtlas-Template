# =============================================================================
# XppAtlas Client — Environment Configuration
# =============================================================================
# Copy this file to .env and adjust values for your developer workstation.
# The .env file is gitignored; never commit secrets.
#
# This project is the CLIENT side of XppAtlas. The XppAtlas MCP server runs
# separately (either on this machine or on a shared LAN server) and serves
# all X++ source via the mcp__xppatlas__* tool surface.
# =============================================================================

# ---------------------------------------------------------------------------
# Standard server connection (optional — server/client split mode, Phase 28)
# ---------------------------------------------------------------------------
# Leave both blank for fully local mode (all models served from this machine).
# See .claude/rules/split-mode.md for the full read/write plane invariants.

# URL of the remote XppAtlas Standard Server that hosts the large standard
# models (ApplicationSuite, ApplicationFoundation, etc.). When set, this
# client fans out read-plane MCP calls (list_models, semantic_search with
# empty model_name, search_artifacts / search_chunks / get_artifact /
# explore_artifact / check_symbol against STANDARD models) to this URL.
# Example: http://10.0.0.50:8765
# XPPATLAS_STANDARD_SERVER_URL=

# Admin bearer token issued by the standard server. Required for any write
# calls to the server (admin-only) and for list_models/semantic_search
# against RESTRICTED / HIDDEN models. Read-only clients touching OPEN
# models only can leave this blank. NEVER commit a real value here —
# keep secrets in .env (gitignored), never in .env.example.
# XPPATLAS_ADMIN_TOKEN=

# ---------------------------------------------------------------------------
# Unreachable-fallback behaviour (Phase 29)
# ---------------------------------------------------------------------------
# When the standard server returns a non-ok envelope, the client inspects
# meta.standard_server.status + meta.standard_server_detail.reason and falls
# through the cascade documented in .claude/rules/fallback-and-evidence.md.
#
# Reason codes produced by the server/client proxy:
#   timeout       — request timed out  → retry-once per fallback rule
#   connect       — TCP-level failure  → drop tier, do not retry
#   http          — 5xx / non-2xx      → drop tier, do not retry
#   unauthorized  — 401/403            → surface as config error, stop
#   empty         — 2xx but empty body → drop tier, do not retry
#   other         — unclassified       → drop tier
#   none          — nothing attempted  → inspect client config
#
# The envelope is advisory; the knobs below tune how the client reacts.

# Timeout in seconds for each HTTP proxy call to the standard server.
# If you're on a slow LAN or VPN, raise this to 30–60. If you'd rather fail
# fast and fall back to the Standard Pack cache, lower to 5.
# XPPATLAS_STANDARD_SERVER_TIMEOUT=15

# Retry policy on reason=timeout. The client always retries once per
# fallback-and-evidence.md; this knob lets you disable that retry on flaky
# links where the second attempt is unlikely to succeed.
# XPPATLAS_STANDARD_SERVER_RETRY_ON_TIMEOUT=true

# When true and the standard server is unreachable, the client silently
# returns whatever local results it has plus meta.standard_server.status.
# When false, MCP read tools surface a structured error instead. Leave true
# for daily work (skills fall through the cascade); set false when debugging
# split-mode issues so the silent-degraded case becomes obvious.
# XPPATLAS_STANDARD_SERVER_SOFT_UNREACHABLE=true

# ---------------------------------------------------------------------------
# Local client stores (custom + vendor models)
# ---------------------------------------------------------------------------

# SQLite knowledge store for this project's custom + vendor models.
XPPATLAS_DB_PATH=data/xppatlas.db

# Model registry (JSON) — lists every model this client knows about.
XPPATLAS_MODEL_REGISTRY_PATH=data/models.json

# Root directory of your D365/X++ source tree served locally.
# Expected layout:
#   models-src/custom/<ModelName>/AxClass/...
#   models-src/vendor/<ModelName>/AxClass/...
XPPATLAS_SOURCE_ROOT=models-src

# Task workspace directories (MCP task-management tools write here).
XPPATLAS_WORKSPACE_BASE=data/workspaces
XPPATLAS_ARCHIVE_DIR=data/archives

# ---------------------------------------------------------------------------
# Semantic search (embeddings + vector store)
# ---------------------------------------------------------------------------

# Pick ONE embedding option:
#
#   A) OpenAI  (cloud, best quality — costs ~$1-2 to embed a custom model)
#      OPENAI_API_KEY=sk-...
#      XPPATLAS_EMBEDDING_MODEL=text-embedding-3-small
#
#   B) Local  (free, offline, ~400 MB download)
#      XPPATLAS_EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
#
OPENAI_API_KEY=
XPPATLAS_EMBEDDING_MODEL=text-embedding-3-small

# Vector store backend. Use "chroma" for anything larger than a small
# custom model; "memory" is for testing only.
XPPATLAS_VECTOR_BACKEND=chroma
XPPATLAS_CHROMA_PATH=data/chroma

# ---------------------------------------------------------------------------
# Client mode / access control
# ---------------------------------------------------------------------------

# Dev mode grants ADMIN role unconditionally. Fine on a developer workstation,
# NEVER on a shared server.
XPPATLAS_DEV_MODE=true

# Log verbosity: DEBUG | INFO | WARNING | ERROR | CRITICAL
# XPPATLAS_LOG_LEVEL=INFO

# ---------------------------------------------------------------------------
# External knowledge (MS Learn + Stack Overflow)
# ---------------------------------------------------------------------------

# Off by default — no network calls made unless this is true.
# XPPATLAS_ENABLE_EXTERNAL_KNOWLEDGE=false
# XPPATLAS_GITHUB_PAT=
# XPPATLAS_STACK_OVERFLOW_API_KEY=
# XPPATLAS_EXTERNAL_CACHE_TTL_HOURS=24
